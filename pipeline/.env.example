# pipeline/ — variabili d'ambiente (modulo Python, isolato dalla dashboard)
#
# Guardrail §5 (root CLAUDE.md): questo processo NON riceve MAI INSTANTLY_API_KEY.
# L'assenza di quella variabile è il confine di isolamento, non una dimenticanza:
# la pipeline non può causare invii perché non ha modo di parlare con Instantly.
# Lo start di ogni script lo verifica a runtime (assert_no_instantly) e aborta
# se la chiave è presente. L'unica scrittura consentita è verso Supabase.

# Enrichment / scraping
APIFY_TOKEN=
PERPLEXITY_API_KEY=
MILLIONVERIFIER_KEY=

# Classificazione flag — LLM OpenAI-compatible (default: DeepSeek).
# base_url + model sono in config.yaml → providers.classify (switchabile a
# Qwen/Moonshot/Zhipu senza toccare il codice). Opzionale: LLM_MODEL per override.
LLM_API_KEY=

# Supabase (sola scrittura DB — service role)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Run control
BUDGET_EUR_MAX=40          # tetto di spesa per run: superato → stop pulito
CLIENT_SLUG=geriko         # tenant di questo run (scrive client_slug su Supabase)
