# pipeline/ — variabili d'ambiente (modulo Python, isolato dalla dashboard)
#
# Guardrail §5 (root CLAUDE.md): questo processo NON riceve MAI INSTANTLY_API_KEY.
# assert_no_instantly() aborta ogni script se la chiave è presente: è il confine
# di isolamento, non una dimenticanza. L'unica scrittura è verso Supabase (opz.).

# Enrichment / scraping
APIFY_API=                 # token Apify (actor id in config.yaml → providers.apify)
PERPLEXITY_API=            # opzionale — provider perplexity_relay (off di default)
MILLIONVERIFIER_API=       # validazione email (opz.: --dry-run la salta)

# Classificazione flag — LLM via OpenRouter (OpenAI-compatible).
# base_url + model in config.yaml → providers.classify (default deepseek/deepseek-chat;
# switchabile a qwen / kimi / glm cambiando una riga). Opz.: LLM_MODEL per override.
OPENROUTER_API=

# Supabase — OPZIONALE. Senza queste due var la pipeline gira in modalità locale
# (scrive i CSV in data/out/, niente DB). Impostale solo se vuoi storico + viste dashboard.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Run control
BUDGET_EUR_MAX=40          # tetto di spesa per run: superato → stop pulito
CLIENT_SLUG=geriko         # tenant di questo run
